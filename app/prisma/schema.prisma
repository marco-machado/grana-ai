datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

enum AccountType {
  CHECKING
  CREDIT
  SAVINGS
}

enum SourceType {
  EMAIL
  CSV
  API
  MANUAL
}

enum StagingStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RecurringFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  YEARLY
}

enum RecurringType {
  SUBSCRIPTION
  BILL
  INSTALLMENT
}

enum InstallmentFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  YEARLY
}

enum BudgetStatus {
  ACTIVE
  PAUSED
}

model Account {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String
  type                 AccountType
  created_at           DateTime             @default(now())
  updated_at           DateTime             @updatedAt
  sources              Source[]
  transactions         Transaction[]
  staging_transactions StagingTransaction[]
  recurring_items      RecurringItem[]
  installment_groups   InstallmentGroup[]
  saving_goals         SavingGoal[]
}

model Source {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String
  type                 SourceType
  identifier           String
  account_id           String               @db.Uuid
  account              Account              @relation(fields: [account_id], references: [id])
  created_at           DateTime             @default(now())
  updated_at           DateTime             @updatedAt
  transactions         Transaction[]
  staging_transactions StagingTransaction[]
  processed_statements ProcessedStatement[]

  @@unique([account_id, type, identifier])
}

model Category {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String
  parent_id            String?              @db.Uuid
  parent               Category?            @relation("CategoryHierarchy", fields: [parent_id], references: [id])
  children             Category[]           @relation("CategoryHierarchy")
  created_at           DateTime             @default(now())
  transactions         Transaction[]
  staging_transactions StagingTransaction[]
  budgets              Budget[]
  recurring_items      RecurringItem[]
  installment_groups   InstallmentGroup[]

  @@unique([name, parent_id])
}

model Budget {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category_id String       @db.Uuid
  category    Category     @relation(fields: [category_id], references: [id])
  amount      Decimal      @db.Decimal(12, 2)
  period      DateTime?    @db.Date
  status      BudgetStatus @default(ACTIVE)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  @@unique([category_id, period])
}

model RecurringItem {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  amount       Decimal            @db.Decimal(12, 2)
  frequency    RecurringFrequency
  next_date    DateTime           @db.Date
  type         RecurringType
  category_id  String?            @db.Uuid
  category     Category?          @relation(fields: [category_id], references: [id])
  account_id   String?            @db.Uuid
  account      Account?           @relation(fields: [account_id], references: [id])
  created_at   DateTime           @default(now())
  updated_at   DateTime           @updatedAt
  transactions Transaction[]
}

model InstallmentGroup {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  description        String
  total_amount       Decimal              @db.Decimal(12, 2)
  installments_total Int
  frequency          InstallmentFrequency
  start_date         DateTime             @db.Date
  category_id        String?              @db.Uuid
  category           Category?            @relation(fields: [category_id], references: [id])
  account_id         String?              @db.Uuid
  account            Account?             @relation(fields: [account_id], references: [id])
  created_at         DateTime             @default(now())
  updated_at         DateTime             @updatedAt
  transactions       Transaction[]
}

model SavingGoal {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  target_amount     Decimal       @db.Decimal(12, 2)
  deadline          DateTime?     @db.Date
  linked_account_id String?       @db.Uuid
  linked_account    Account?      @relation(fields: [linked_account_id], references: [id])
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt
  transactions      Transaction[]
}

model Transaction {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date              DateTime  @db.Date
  description_raw   String
  description_clean String
  amount            Decimal   @db.Decimal(12, 2)
  account_id        String    @db.Uuid
  account           Account   @relation(fields: [account_id], references: [id])
  source_id         String    @db.Uuid
  source            Source    @relation(fields: [source_id], references: [id])
  category_id          String?           @db.Uuid
  category             Category?         @relation(fields: [category_id], references: [id])
  is_recurring         Boolean           @default(false)
  recurring_item_id    String?           @db.Uuid
  recurring_item       RecurringItem?    @relation(fields: [recurring_item_id], references: [id], onDelete: SetNull)
  installment_group_id String?           @db.Uuid
  installment_group    InstallmentGroup? @relation(fields: [installment_group_id], references: [id], onDelete: SetNull)
  is_savings_transfer  Boolean           @default(false)
  saving_goal_id       String?           @db.Uuid
  saving_goal          SavingGoal?       @relation(fields: [saving_goal_id], references: [id], onDelete: SetNull)
  created_at           DateTime          @default(now())
  updated_at           DateTime          @updatedAt

  @@unique([account_id, date, amount, description_raw])
}

model StagingTransaction {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date                DateTime      @db.Date
  description_raw     String
  description_clean   String
  amount              Decimal       @db.Decimal(12, 2)
  account_id          String        @db.Uuid
  account             Account       @relation(fields: [account_id], references: [id])
  source_id           String        @db.Uuid
  source              Source        @relation(fields: [source_id], references: [id])
  category_id         String?       @db.Uuid
  category            Category?     @relation(fields: [category_id], references: [id])
  category_suggestion String?
  confidence_score    Decimal?      @db.Decimal(3, 2)
  status              StagingStatus @default(PENDING)
  statement_hash      String
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt
}

model ProcessedStatement {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source_id      String   @db.Uuid
  source         Source   @relation(fields: [source_id], references: [id])
  statement_hash String   @unique
  processed_at   DateTime @default(now())
}
